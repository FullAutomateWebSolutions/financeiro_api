generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["gestao"]
}

model cartao {
  codCartao        Int                @id @default(autoincrement())
  tipoCartao       String
  descCartao       String
  indAtivo         Boolean?           @default(true)
  dataCriacao      DateTime?          @default(now()) @db.Timestamp(6)
  dataAtualizacao  DateTime?          @default(now()) @db.Timestamp(6)
  codUsuario       Int
  usuario          usuario            @relation(fields: [codUsuario], references: [codUsuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_cartao_usuario")
  movimentacao     movimentacao[]
  movimentacaohist movimentacaohist[]

  @@schema("gestao")
}

model categoria {
  codCategoria     Int                @id @default(autoincrement())
  descCategoria    String
  indAtivo         Boolean?           @default(true)
  dataCriacao      DateTime?          @default(now()) @db.Timestamp(6)
  dataAtualizacao  DateTime?          @default(now()) @db.Timestamp(6)
  codUsuario       Int
  usuario          usuario            @relation(fields: [codUsuario], references: [codUsuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_categoria_usuario")
  movimentacao     movimentacao[]
  movimentacaohist movimentacaohist[]

  @@schema("gestao")
}

model conta {
  codConta         Int                @id @default(autoincrement())
  tipoConta        String
  descConta        String
  indAtivo         Boolean?           @default(true)
  dataCriacao      DateTime?          @default(now()) @db.Timestamp(6)
  dataAtualizacao  DateTime?          @default(now()) @db.Timestamp(6)
  codUsuario       Int
  usuario          usuario            @relation(fields: [codUsuario], references: [codUsuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_conta_usuario")
  movimentacao     movimentacao[]
  movimentacaohist movimentacaohist[]

  @@schema("gestao")
}

model formapagamento {
  codFormPag       Int                @id @default(autoincrement())
  tipoFormPag      String
  descFormPag      String
  indAtivo         Boolean?           @default(true)
  dataCriacao      DateTime?          @default(now()) @db.Timestamp(6)
  dataAtualizacao  DateTime?          @default(now()) @db.Timestamp(6)
  codUsuario       Int
  usuario          usuario            @relation(fields: [codUsuario], references: [codUsuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_formpag_usuario")
  movimentacao     movimentacao[]
  movimentacaohist movimentacaohist[]

  @@schema("gestao")
}

model movimentacao {
  codMovimentacao    BigInt             @id @default(autoincrement())
  dataMov            DateTime           @db.Timestamp(6)
  descMovimento      String
  valorUnit          Decimal            @db.Decimal(12, 2)
  porcJuros          Decimal?           @default(0) @db.Decimal(12, 2)
  valorJuros         Decimal?           @default(0) @db.Decimal(12, 2)
  tipoParcelamento   Int?
  qtdParcAtual       Int?
  qtdParcFinal       Int?
  qtdParcPendente    Int?
  valorTotalPendente Decimal?           @db.Decimal(12, 2)
  dataFimMov         DateTime?          @db.Timestamp(6)
  codFormPag         Int
  codConta           Int
  codStatus          Int
  codCategoria       Int
  codCartao          Int?
  codUsuario         Int
  indAtivo           Boolean?           @default(true)
  dataCriacao        DateTime?          @default(now()) @db.Timestamp(6)
  dataAtualizacao    DateTime?          @default(now()) @db.Timestamp(6)
  dataIntegracao     DateTime?          @db.Timestamp(6)
  dataFechamento     DateTime?          @db.Timestamp(6)
  cartao             cartao?            @relation(fields: [codCartao], references: [codCartao], onDelete: NoAction, onUpdate: NoAction, map: "fk_mov_cartao")
  categoria          categoria          @relation(fields: [codCategoria], references: [codCategoria], onDelete: NoAction, onUpdate: NoAction, map: "fk_mov_categoria")
  conta              conta              @relation(fields: [codConta], references: [codConta], onDelete: NoAction, onUpdate: NoAction, map: "fk_mov_conta")
  formapagamento     formapagamento     @relation(fields: [codFormPag], references: [codFormPag], onDelete: NoAction, onUpdate: NoAction, map: "fk_mov_formapag")
  status             status             @relation(fields: [codStatus], references: [codStatus], onDelete: NoAction, onUpdate: NoAction, map: "fk_mov_status")
  usuario            usuario            @relation(fields: [codUsuario], references: [codUsuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_mov_usuario")
  movimentacaohist   movimentacaohist[]

  @@index([codCartao], map: "idx_mov_cartao")
  @@index([codCategoria], map: "idx_mov_categoria")
  @@index([codConta], map: "idx_mov_conta")
  @@index([dataMov], map: "idx_mov_data")
  @@index([codStatus], map: "idx_mov_status")
  @@index([codUsuario], map: "idx_mov_usuario")
  @@schema("gestao")
}

model movimentacaohist {
  codMovimentacaoHist BigInt          @id @default(autoincrement())
  codMovimentacao     BigInt?
  dataMov             DateTime?       @db.Timestamp(6)
  descMovimento       String?
  valorUnit           Decimal?        @db.Decimal(12, 2)
  tipoParcelamento    Int?
  qtdParcAtual        Int?
  qtdParcFinal        Int?
  qtdParcPendente     Int?
  valorTotalPendente  Decimal?        @db.Decimal(12, 2)
  dataFimMov          DateTime?       @db.Timestamp(6)
  codFormPag          Int?
  codConta            Int?
  codStatus           Int?
  codCategoria        Int?
  codCartao           Int?
  codUsuario          Int?
  indAtivo            Boolean?
  dataCriacao         DateTime?       @db.Timestamp(6)
  dataAtualizacao     DateTime?       @db.Timestamp(6)
  dataIntegracao      DateTime?       @db.Timestamp(6)
  dataFechamento      DateTime?       @db.Timestamp(6)
  dataHistorico       DateTime?       @default(now()) @db.Timestamp(6)
  cartao              cartao?         @relation(fields: [codCartao], references: [codCartao], onDelete: NoAction, onUpdate: NoAction, map: "fk_hist_cartao")
  categoria           categoria?      @relation(fields: [codCategoria], references: [codCategoria], onDelete: NoAction, onUpdate: NoAction, map: "fk_hist_categoria")
  conta               conta?          @relation(fields: [codConta], references: [codConta], onDelete: NoAction, onUpdate: NoAction, map: "fk_hist_conta")
  formapagamento      formapagamento? @relation(fields: [codFormPag], references: [codFormPag], onDelete: NoAction, onUpdate: NoAction, map: "fk_hist_formapag")
  movimentacao        movimentacao?   @relation(fields: [codMovimentacao], references: [codMovimentacao], onUpdate: NoAction, map: "fk_hist_mov")
  status              status?         @relation(fields: [codStatus], references: [codStatus], onDelete: NoAction, onUpdate: NoAction, map: "fk_hist_status")
  usuario             usuario?        @relation(fields: [codUsuario], references: [codUsuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_hist_usuario")

  @@schema("gestao")
}

model status {
  codStatus        Int                @id @default(autoincrement())
  descStatus       String             @db.VarChar(100)
  descCompleta     String?            @db.VarChar(255)
  indAtivo         Boolean?           @default(true)
  dataCriacao      DateTime?          @default(now()) @db.Timestamp(6)
  dataAtualizacao  DateTime?          @default(now()) @db.Timestamp(6)
  codUsuario       Int
  movimentacao     movimentacao[]
  movimentacaohist movimentacaohist[]
  usuario          usuario            @relation(fields: [codUsuario], references: [codUsuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_status_usuario")

  @@schema("gestao")
}

model usuario {
  codUsuario       Int                @id @default(autoincrement())
  nome             String             @db.VarChar(150)
  email            String             @unique @db.VarChar(150)
  senha            String             @db.VarChar(255)
  role             usuario_role       @default(USER)
  indAtivo         Boolean?           @default(true)
  dataCriacao      DateTime?          @default(now()) @db.Timestamp(6)
  dataAtualizacao  DateTime?          @default(now()) @db.Timestamp(6)
  cartao           cartao[]
  categoria        categoria[]
  conta            conta[]
  formapagamento   formapagamento[]
  movimentacao     movimentacao[]
  movimentacaohist movimentacaohist[]
  status           status[]

  @@schema("gestao")
}

enum usuario_role {
  ADMIN
  USER
  MANAGER

  @@schema("gestao")
}
